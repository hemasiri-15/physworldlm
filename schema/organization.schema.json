      },
      "lifecycle": { "status": "active" }
    },
    {
      "id": "a1b2c3d4-0003-0001-0001-000000000003",
      "org_id": "ORG-ROBOTFLEET-ALPHA",
      "name": "Alpha Autonomous Logistics Fleet",
      "short_name": "ALPHA-ALF",
      "description": "Fully autonomous robot fleet for forward logistics resupply.",
      "version": "1.0.0",
      "classification": {
        "org_type": "autonomous_robot_fleet",
        "sector": "autonomous_systems",
