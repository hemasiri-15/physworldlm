      },
      "TacticalPicture": {
        "id": "pwlm:sub:sys:TactPic",
        "label": "Tactical Picture / Situational Awareness",
        "inputs": ["sonar tracks", "ESM", "communication intelligence", "data link"],
        "display_types": ["geographic plot", "bearing-time recorder", "waterfall display"]
      },
      "ThreatEvaluation": {
        "id": "pwlm:sub:sys:ThreatEval",
        "functions": ["hostile classification", "threat prioritization", "torpedo detection"]
      },
      "TrackCorrelation": {
        "id": "pwlm:sub:sys:TrackCorr",
        "functions": ["multi-sensor fusion", "ambiguity resolution", "track splitting detection"]
      },
      "BattleDamageAssessment": {
        "id": "pwlm:sub:sys:BDA",
        "inputs": ["acoustic hit detection", "sonar track loss", "ESM silence"]
      },
      "MissionPlanning": {
        "id": "pwlm:sub:sys:MissionPlan",
        "functions": ["route optimization", "patrol box planning", "threat avoidance routing", "mine avoidance"]
      },
      "DecisionSupport": {
        "id": "pwlm:sub:sys:DSS",
        "label": "AI Decision Support",
        "functions": ["COA recommendation", "torpedo evasion maneuver", "probability of detection modeling"]
      }
    }
  },

