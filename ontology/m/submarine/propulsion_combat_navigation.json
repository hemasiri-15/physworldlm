        "sim_properties": ["solution_time_min", "range_accuracy_pct", "course_accuracy_deg"],
        "simulation_note": "TMA is the fundamental passive ASW closure problem; simulation must model bearing line geometry."
      },
      "WeaponAssignment": {
        "id": "pwlm:sub:sys:WeaponAssign",
        "functions": ["optimal weapon selection", "tube allocation", "shoot-look-shoot planning"]
      },
      "EngagementPlanning": {
        "id": "pwlm:sub:sys:EngagePlan",
