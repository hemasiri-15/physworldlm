# ---------------------------------------------------------------
# Helper: mode() constructor
# v2 adds: priority, cpu_load_pct, memory_mb, net_bw_mbps,
#          thermal_kw, expected_duration_s, mission_phase,
#          failure_probability, confidence
# ---------------------------------------------------------------
def mode(id_, name, aliases, desc, category, parent, children,
         platforms, radar_types, missions, bands,
         scan_pattern, beam_pattern, emission,
         power_w, cooling, max_targets,
         entry_cond, exit_cond, transitions, related_modes, components,
         ew_vuln, eccm, env_constraints,
         ai_weight, maturity, references,
         # v2 resource fields
         priority=5, cpu_load_pct=30, memory_mb=512,
         net_bw_mbps=0, thermal_kw=2.0,
         expected_duration_s=None, mission_phase="General",
         failure_probability=0.0001, confidence=1.0,
         metadata=None):
    return {
        "id": id_, "name": name, "aliases": aliases,
        "description": desc, "category": category,
        "parent": parent, "children": children,
        "applicable_platforms": platforms,
        "supported_radar_types": radar_types,
        "mission_roles": missions,
        "operating_band_constraints": bands,
        "scan_pattern": scan_pattern,
        "beam_pattern": beam_pattern,
        "emission_type": emission,
        "power_consumption_W": power_w,
        "cooling_required": cooling,
        "max_simultaneous_targets": max_targets,
        "entry_conditions": entry_cond,
        "exit_conditions": exit_cond,
        "allowed_transitions": transitions,
        "related_modes": related_modes,
        "required_components": components,
        "ew_vulnerability": ew_vuln,
        "eccm_capability": eccm,
        "environmental_constraints": env_constraints,
        "ai_decision_weight": ai_weight,
        "maturity_level": maturity,
        "references": references,
        # v2 resource budget
        "resource_budget": {
            "priority": priority,
            "cpu_load_pct": cpu_load_pct,
            "memory_mb": memory_mb,
            "net_bw_mbps": net_bw_mbps,
            "thermal_kw": thermal_kw,
            "expected_duration_s": expected_duration_s,
        },
        "mission_phase": mission_phase,
        "failure_probability": failure_probability,
        "confidence": confidence,
        "metadata": metadata or {}
    }

