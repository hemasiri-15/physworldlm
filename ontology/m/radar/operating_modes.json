# ==============================================================
# AGGREGATE ALL MODES
# ==============================================================
def build_all_modes():
    all_modes = {}
    for d in [standby, search, acquisition, tracking, fire_control, a2a,
              mapping, maritime, bmd, cuas, ew_modes, passive, identification,
              calibration, weather, navigation, ai_modes, networking,
              maintenance, emergency]:
        all_modes.update(d)
    return all_modes

ALL_MODES = build_all_modes()

# Stitch into ontology
ontology["RadarOperatingModes"] = ALL_MODES

if __name__ == "__main__":
    import json
    # Validate all modes have required keys
    required = {"id","name","aliases","description","category","parent","children",
                "applicable_platforms","supported_radar_types","mission_roles",
                "operating_band_constraints","scan_pattern","beam_pattern","emission_type",
                "power_consumption_W","cooling_required","max_simultaneous_targets",
                "entry_conditions","exit_conditions","allowed_transitions","related_modes",
                "required_components","ew_vulnerability","eccm_capability",
                "environmental_constraints","ai_decision_weight","maturity_level",
                "references","resource_budget","mission_phase",
                "failure_probability","confidence","metadata"}

    errors = []
    for k, v in ALL_MODES.items():
        missing = required - set(v.keys())
        if missing:
            errors.append(f"{k}: missing {missing}")
    if errors:
        print("SCHEMA ERRORS:")
        for e in errors: print(" ", e)
    else:
        print(f"✅ All {len(ALL_MODES)} modes valid.")
        print(f"   Categories: {len(set(v['category'] for v in ALL_MODES.values()))}")
        cats = {}
        for v in ALL_MODES.values():
            cats[v['category']] = cats.get(v['category'], 0) + 1
        for cat, n in sorted(cats.items()):
            print(f"   {cat:25s}: {n:3d} modes")
