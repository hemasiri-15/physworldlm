{
  "batch_size": 64,
  "num_workers": 4,
  "epochs": 50,
  "lr_backbone": 2e-05,
  "lr_projection": 5e-05,
  "lr_heads": 0.0001,
  "weight_decay": 0.01,
  "gradient_clip": 1.0,
  "accumulation_steps": 1,
  "warmup_ratio": 0.06,
  "patience": 8,
  "checkpoint_dir": "checkpoints",
  "device": "auto",
  "mixed_precision": true,
  "scheduler_tmax": 50,
  "save_every_epoch": true,
  "freeze_backbone_epochs": 0,
  "resume_checkpoint": null,
  "ema_decay": 0.999,
  "use_ema": true,
  "loss_weights": {},
  "use_tensorboard": true,
  "use_wandb": false,
  "wandb_project": "physworldlm-entity",
  "dataset_dir": "datasets/entity",
  "seed": 42,
  "debug": false,
  "save_confusion_matrices": true,
  "save_plots": true
}